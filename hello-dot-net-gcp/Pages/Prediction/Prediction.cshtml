@page
@model YourAppName.Pages.Prediction.PredictionModel
@{
    ViewData["Title"] = "Tenant Eviction Prediction";
}

<div class="container mt-5">
    <h2>Eviction Risk Assessment</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Monthly Income ($)</label>
                    <input type="number" step="0.01" class="form-control" asp-for="TenantData.monthly_income" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Monthly Debt ($)</label>
                    <input type="number" step="0.01" class="form-control" asp-for="TenantData.monthly_debt" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Credit Score</label>
                    <input type="number" class="form-control" asp-for="TenantData.credit_score" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Proposed Rent ($)</label>
                    <input type="number" step="0.01" class="form-control" asp-for="TenantData.proposed_rent" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Employment Tenure (Months)</label>
                    <input type="number" class="form-control" asp-for="TenantData.employment_tenure_months" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Years at Previous Address</label>
                    <input type="number" step="0.1" class="form-control" asp-for="TenantData.years_at_prev_address" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Late Payments (Last 24 months)</label>
                    <input type="number" class="form-control" asp-for="TenantData.late_payment_count" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Previous Evictions (0 or 1)</label>
                    <select class="form-select" asp-for="TenantData.prev_evictions">
                        <option value="0">0 - No Evictions</option>
                        <option value="1">1 - Has Prior Eviction</option>
                    </select>
                </div>
                
                <button type="submit" class="btn btn-primary w-100">Run Prediction Model</button>
            </form>
        </div>

        <div class="col-md-6">
            @if (Model.PredictionResult != null)
            {
                <div class="card mt-4">
                    <div class="card-header bg-dark text-white">
                        Prediction Result
                    </div>
                    <div class="card-body">
                        <h4 class="card-title text-primary">Assigned: @Model.PredictionResult</h4>
                        <p class="card-text">
                            <strong>Risk Probability:</strong> @(Model.RiskProbability * 100)%
                        </p>
                        @if (Model.PredictionResult == "Class 1")
                        {
                            <div class="alert alert-danger">High Risk: Eviction probability is elevated based on the financial and historical indicators provided.</div>
                        }
                        else
                        {
                            <div class="alert alert-success">Low Risk: Tenant profile aligns with stable historical parameters.</div>
                        }
                    </div>
                </div>
            }

            @if (Model.ErrorMessage != null)
            {
                <div class="alert alert-danger mt-4">
                    <strong>System Error:</strong> @Model.ErrorMessage
                </div>
            }
        </div>
    </div>
</div>